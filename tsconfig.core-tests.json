{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./.tmp/core-tests",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "types": ["node"],
    "incremental": false
  },
  "include": [
    "lib/constants.ts",
    "lib/currencies.ts",
    "lib/pairs.ts",
    "lib/storage.ts",
    "lib/types.ts",
    "lib/formulas/**/*.ts",
    "tests/core-behavior.test.ts"
  ],
  "exclude": ["node_modules"]
}
